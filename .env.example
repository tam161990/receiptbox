# SQLite for local dev. On Railway use file:/data/prod.db with a volume at /data.
DATABASE_URL="file:./dev.db"

# Railway: mount a volume at /data and set DATA_DIR=/data
# DATA_DIR="/data"

# OpenAI API key for document analysis.
OPENAI_API_KEY="sk-..."

# Optional: override default model (defaults to gpt-4o-mini).
OPENAI_MODEL="gpt-4o-mini"

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."

# Bot username without @ (required for Telegram Login Widget on the website).
TELEGRAM_BOT_USERNAME="ReceiptBox_bot"

# Random secret used to validate webhook calls (see README).
TELEGRAM_WEBHOOK_SECRET="some-long-random-string"

# Public URL (production: https://receiptbox.online)
APP_URL="https://receiptbox.online"

# Optional: shared dev login PIN for the web dashboard.
# Leave empty in production.
DEV_LOGIN_PIN=""
