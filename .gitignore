# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (must NOT commit)
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma / sqlite
/prisma/*.db
/prisma/*.db-journal
/prisma/migrations/dev.db*

# uploaded user files (the directory is kept via .gitkeep, contents are ignored)
/storage/uploads/*
!/storage/uploads/.gitkeep
